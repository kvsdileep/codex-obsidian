# Raw ingestion sources stay local. Keep only folder placeholders in git.
.raw/**
!.raw/
!.raw/**/
!.raw/**/.gitkeep

# Large media by default
*.mkv
*.mp4
*.mov
*.avi

# Keep attachment folder but avoid accidentally committing huge files.
_attachments/*
!_attachments/.gitkeep
